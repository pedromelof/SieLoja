<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Base application theme, dependent on API level. This theme is replaced
        by AppBaseTheme from res/values-vXX/styles.xml on newer devices.
    -->
    <style name="AppBaseTheme" parent="android:Theme.Holo.Light">
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/styles.xml, while customizations related to
            backward-compatibility can go here.
        -->
    </style>

    <!-- Application theme. -->
    <style name="AppTheme" parent="AppBaseTheme">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>

    <style name="button">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@drawable/button</item>
        <item name="android:padding">@dimen/margin_15</item>
    </style>

    <style name="button_menu">
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/menu_button</item>
        <item name="android:paddingTop">@dimen/margin_40</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="numberPicker">
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="parcial_true">
        <item name="android:background">@drawable/parcial_button_true</item>
        <item name="android:textColor">@color/text_color</item>
    </style>

    <style name="parcial_false">
        <item name="android:background">@drawable/parcial_button_false</item>
        <item name="android:textColor">@color/button_color</item>
    </style>
</resources>
