<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" >

    <item
        android:bottom="1dp"
        android:left="-2dp"
        android:right="1dp"
        android:top="-2dp">
        <shape android:shape="rectangle" >
            <stroke
                android:width="1dp"
                android:color="@color/background" />

            <solid
                android:color="@android:color/transparent"/>

            <padding
                android:bottom="@dimen/margin_15"
                android:left="@dimen/margin_15"
                android:right="0dp"
                android:top="@dimen/margin_15" >
            </padding>
        </shape>
    </item>

</layer-list>