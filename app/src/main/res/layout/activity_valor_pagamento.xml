<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <TextView
        android:id="@+id/text_valor_pagamento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="R$ 0,00"
        android:textColor="@color/text_color"
        android:textSize="44sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@color/text_color" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginLeft="@dimen/margin_10"
        android:layout_marginRight="@dimen/margin_10"
        android:columnCount="3"
        android:rowCount="4">

        <Button
            android:id="@+id/btn_num_1"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="1"
            android:textSize="28sp"/>

        <Button
            android:id="@+id/btn_num_2"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="2"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_3"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="3"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_4"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="4"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_5"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="5"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_6"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="6"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_7"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="7"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_8"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="8"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_9"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="9"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_00"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="00"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_0"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="0"
            android:textSize="28sp"/>
        <Button
            android:id="@+id/btn_num_x"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="X"
            android:textSize="28sp"/>

    </GridLayout>

    <Button
        android:id="@+id/button_efetuar_pagamento"
        style="@style/button"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="@dimen/margin_15"
        android:layout_marginBottom="24dp"
        android:text="EFETUAR PAGAMENTO"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>