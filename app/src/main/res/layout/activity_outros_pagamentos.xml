<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingVertical="15dp">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="@dimen/margin_10"
        android:layout_marginRight="@dimen/margin_10"
        android:layout_weight="1"
        android:columnCount="1"
        android:rowCount="3">

        <Button
            android:id="@+id/btnValeRefeicao"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="VALE REFEIÇÃO"
            android:textSize="28sp" />
        <Button
            android:id="@+id/btnValeAlimentacao"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="VALE ALIMENTAÇÃO"
            android:textSize="28sp" />
        <Button
            android:id="@+id/btnDinheiro"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="@dimen/margin_05"
            android:layout_marginRight="@dimen/margin_05"
            android:layout_weight="1"
            android:text="DINHEIRO"
            android:textSize="28sp" />
    </GridLayout>

</LinearLayout>